# APJ TRUE LIFE — api-gateway Environment Variables

SPRING_PROFILES_ACTIVE=local

# auth-service JWKS URL (internal Railway private network URL in prod)
AUTH_SERVICE_JWKS_URL=http://auth-service.railway.internal:8081/api/v1/auth/.well-known/jwks.json

# Internal shared secret — injected into X-Internal-Secret header by gateway, validated by every downstream service
INTERNAL_GATEWAY_SECRET=

# CORS — production domain
ALLOWED_CORS_ORIGIN=https://apjtruelife.com

# Rate limits
RATE_LIMIT_UNAUTH_PER_MIN=100
RATE_LIMIT_AUTH_PER_MIN=500

# Downstream service URLs (Railway private network)
AUTH_SERVICE_BASE_URL=http://auth-service.railway.internal:8081
PATIENT_SERVICE_BASE_URL=http://patient-service.railway.internal:8082
DOCTOR_SERVICE_BASE_URL=http://doctor-service.railway.internal:8083
TREATMENT_SERVICE_BASE_URL=http://treatment-service.railway.internal:8084
APPOINTMENT_SERVICE_BASE_URL=http://appointment-service.railway.internal:8085
CHAT_SERVICE_BASE_URL=http://chat-service.railway.internal:8086
NOTIFICATION_SERVICE_BASE_URL=http://notification-service.railway.internal:8087
MEDIA_SERVICE_BASE_URL=http://media-service.railway.internal:8088
