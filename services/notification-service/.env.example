# APJ TRUE LIFE — notification-service Environment Variables
# NOTE: This service uses Firebase Admin SDK for FCM messaging ONLY. No firebase.auth() usage.

SPRING_PROFILES_ACTIVE=local
DATABASE_URL_SESSION=
DATABASE_URL_RUNTIME=

# Firebase Admin SDK service account JSON — base64 encoded
# base64 -w 0 firebase-service-account.json
# Goes ONLY into this service. No other service needs Firebase Admin SDK.
FIREBASE_SERVICE_ACCOUNT_KEY=

INTERNAL_GATEWAY_SECRET=
