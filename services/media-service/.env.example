# APJ TRUE LIFE — media-service Environment Variables
# This service holds the ONLY copy of SUPABASE_SERVICE_ROLE_KEY in the backend.
# NEVER put this key in Flutter, Next.js, or any other service.

SPRING_PROFILES_ACTIVE=local

# Supabase project URL (e.g. https://abcdefghijkl.supabase.co)
SUPABASE_URL=

# Supabase service-role key — SERVER-SIDE ONLY, never shipped to any client
SUPABASE_SERVICE_ROLE_KEY=

# Internal gateway shared secret
INTERNAL_GATEWAY_SECRET=

# Downstream service URLs for ownership validation
PATIENT_SERVICE_BASE_URL=http://localhost:8082
TREATMENT_SERVICE_BASE_URL=http://localhost:8084
