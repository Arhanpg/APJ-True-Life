# APJ TRUE LIFE — auth-service .env.example
# Copy to .env and fill in real values.
# DO NOT commit .env files.

PORT=8081
# Supabase pooler — TRANSACTION mode (port 6543) for runtime
DATABASE_URL_RUNTIME=jdbc:postgresql://aws-0-ap-south-1.pooler.supabase.com:6543/postgres?user=postgres.YOURPROJECT&password=YOURPASSWORD&prepareThreshold=0
# Supabase direct — SESSION mode (port 5432) for Flyway migrations
DATABASE_URL_SESSION=jdbc:postgresql://aws-0-ap-south-1.pooler.supabase.com:5432/postgres?user=postgres.YOURPROJECT&password=YOURPASSWORD

# RS256 keypair for Doctor/Admin JWT
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_RS256_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----
JWT_RS256_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----

JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800
SENTRY_DSN=
