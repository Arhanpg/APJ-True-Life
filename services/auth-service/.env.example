# APJ TRUE LIFE — auth-service Environment Variables
# Copy this file to .env and fill in REAL values for local dev.
# NEVER commit .env with real values. Real prod values go into Railway dashboard only.

# Spring profile (local | railway)
SPRING_PROFILES_ACTIVE=local

# Database — SESSION mode (port 5432) for Flyway migrations ONLY
# Format: jdbc:postgresql://<host>:5432/<db>?user=<user>&password=<pass>
DATABASE_URL_SESSION=

# Database — RUNTIME mode (port 6543, Supavisor transaction pooler) for HikariCP
# IMPORTANT: Must include ?prepareThreshold=0 (ADR-012 — Supavisor transaction-mode incompatibility)
DATABASE_URL_RUNTIME=

# RS256 JWT keypair — generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Store as base64-encoded PEM: base64 -w 0 private.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# OTP hashing pepper — a random secret, separate from the DB credential
# Generate: openssl rand -hex 32
OTP_HASH_PEPPER=

# SMS Gateway (MSG91 default — see docs/APJ_TRUE_LIFE_V2_BUILD_PROMPT_GUIDE.md Part D.5)
SMS_GATEWAY_PROVIDER=msg91
SMS_GATEWAY_API_KEY=
SMS_GATEWAY_SENDER_ID=APJTRL
SMS_GATEWAY_TEMPLATE_ID=

# Internal gateway shared secret (must match api-gateway value)
INTERNAL_GATEWAY_SECRET=
