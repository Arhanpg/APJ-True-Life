# =======================================================================
# APJ TRUE LIFE — Environment Variables Reference
# Copy this file, fill in real values, rename per platform instructions
# NEVER commit files with real values to GitHub
# =======================================================================

# -----------------------------------------------------------------------
# FIREBASE (from console.firebase.google.com → Project Settings → General)
# -----------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy_REPLACE_ME
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# -----------------------------------------------------------------------
# BACKEND API BASE URL
# Local dev: http://localhost:8080/api/v1
# Production: https://your-gateway.railway.app/api/v1
# -----------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# -----------------------------------------------------------------------
# CLOUDINARY (from cloudinary.com → Dashboard)
# -----------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=apj_upload

# -----------------------------------------------------------------------
# BACKEND / SPRING BOOT (Railway env vars — NOT committed)
# These are set in Railway dashboard, not in files
# -----------------------------------------------------------------------
JWT_SECRET=replace_with_output_of_openssl_rand_base64_64
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...entire json minified...}
FCM_SERVER_KEY=AAAA_replace_me_from_firebase_cloud_messaging
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=replace_me
DATABASE_URL=jdbc:postgresql://ep-xxx.ap-south-1.aws.neon.tech/apjtruelife?currentSchema=auth&sslmode=require
DATABASE_USERNAME=your_neon_username
DATABASE_PASSWORD=your_neon_password
SERVER_PORT=8080
