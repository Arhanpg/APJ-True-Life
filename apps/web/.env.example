# APJ TRUE LIFE — apps/web (Next.js Dashboard) Environment Variables
# NOTE: firebase/auth is REMOVED. Only firebase/app + firebase/messaging are used (Web Push).
# NEVER put any Supabase key or backend secret in this file.

# API Gateway URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Firebase config — messaging/Web Push scope ONLY (auth is unused)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Sentry (optional in dev)
NEXT_PUBLIC_SENTRY_DSN=
