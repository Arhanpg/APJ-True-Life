# APJ TRUE LIFE — apps/mobile (Flutter App) Environment Variables
# Store these in --dart-define or a .env loader. NEVER hardcode in Dart source.
# NOTE: firebase_auth is REMOVED from pubspec.yaml. Only firebase_core + firebase_messaging remain.

# API Gateway base URL
API_BASE_URL=http://10.0.2.2:8080

# Firebase config — messaging scope ONLY
FIREBASE_PROJECT_ID=
# google-services.json handles Android Firebase config — do not commit that file
# GoogleService-Info.plist handles iOS Firebase config — do not commit that file

# Sentry DSN (optional in dev)
SENTRY_DSN=
