app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment secrets — NEVER commit real .env
.env
# DO commit .env.example so other devs know what vars are needed
!.env.example

# Firebase — google-services contains public API keys so it IS safe to commit
# but if you rotate keys, regenerate from Firebase console
